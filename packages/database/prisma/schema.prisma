generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  CASHIER
}

enum SaleStatus {
  OPEN
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CHECK
  CREDIT_CARD
  DEBIT_CARD
  STORE_CREDIT
  FOOD_VOUCHER
  MEAL_VOUCHER
  GIFT_VOUCHER
  FUEL_VOUCHER
  OTHER
  PIX
  CASHBACK
  MERCADO_PAGO
}

enum MovementType {
  IN
  OUT
  ADJUSTMENT
}

enum SyncEntity {
  product
  sale
  stock
  cash_session
}

enum SyncOperationType {
  UPSERT_PRODUCT
  UPSERT_STOCK
  CREATE_SALE
  OPEN_CASH_SESSION
  CLOSE_CASH_SESSION
}

enum SyncStatus {
  PENDING
  PROCESSING
  FAILED
  SYNCED
  CONFLICT
}

model Organization {
  id          String        @id @default(cuid())
  name        String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  stores      Store[]
  users       User[]
  products    Product[]
  sales       Sale[]
  imports     NfeImport[]
  syncCursors SyncCursor[]
}

model Store {
  id             String          @id @default(cuid())
  organizationId String
  name           String
  code           String          @unique
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sales          Sale[]
  stockBalances  StockBalance[]
  cashSessions   CashSession[]
  syncQueue      SyncQueue[]
}

model User {
  id             String        @id @default(cuid())
  organizationId String
  email          String        @unique
  name           String
  role           UserRole
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sales          Sale[]
  cashSessions   CashSession[]
}

model Product {
  id             String           @id @default(cuid())
  organizationId String
  sku            String
  barcode        String?
  name           String
  description    String?
  unit           String           @default("UN")
  costPrice      Decimal          @db.Decimal(12, 2)
  salePrice      Decimal          @db.Decimal(12, 2)
  minStock       Decimal          @default(0) @db.Decimal(12, 3)
  ncm            String?
  cfop           String?
  isActive       Boolean          @default(true)
  version        Int              @default(1)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  saleItems      SaleItem[]
  stockBalances  StockBalance[]
  stockMovements StockMovement[]

  @@unique([organizationId, sku])
}

model StockBalance {
  id         String   @id @default(cuid())
  storeId     String
  productId   String
  quantity    Decimal  @default(0) @db.Decimal(12, 3)
  updatedAt   DateTime @updatedAt
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([storeId, productId])
}

model StockMovement {
  id         String       @id @default(cuid())
  storeId     String
  productId   String
  type        MovementType
  quantity    Decimal      @db.Decimal(12, 3)
  reason      String
  createdAt   DateTime     @default(now())
  product     Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Sale {
  id             String         @id @default(cuid())
  organizationId String
  storeId        String
  operatorId     String
  externalRef    String?
  status         SaleStatus
  subtotalAmount Decimal        @db.Decimal(12, 2)
  discountAmount Decimal        @default(0) @db.Decimal(12, 2)
  totalAmount    Decimal        @db.Decimal(12, 2)
  version        Int            @default(1)
  syncedAt       DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  store          Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  operator       User           @relation(fields: [operatorId], references: [id], onDelete: Restrict)
  items          SaleItem[]
  payments       SalePayment[]
}

model SaleItem {
  id             String    @id @default(cuid())
  saleId         String
  productId      String
  quantity       Decimal   @db.Decimal(12, 3)
  unitPrice      Decimal   @db.Decimal(12, 2)
  discountAmount Decimal   @default(0) @db.Decimal(12, 2)
  totalAmount    Decimal   @db.Decimal(12, 2)
  sale           Sale      @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product        Product   @relation(fields: [productId], references: [id], onDelete: Restrict)
}

model SalePayment {
  id         String        @id @default(cuid())
  saleId      String
  method      PaymentMethod
  amount      Decimal       @db.Decimal(12, 2)
  reference   String?
  createdAt   DateTime      @default(now())
  sale        Sale          @relation(fields: [saleId], references: [id], onDelete: Cascade)
}

model CashSession {
  id            String   @id @default(cuid())
  storeId        String
  openedById     String
  openedAt       DateTime @default(now())
  closedAt       DateTime?
  openingAmount  Decimal  @db.Decimal(12, 2)
  closingAmount  Decimal? @db.Decimal(12, 2)
  status         String   @default("OPEN")
  store          Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  openedBy       User     @relation(fields: [openedById], references: [id], onDelete: Restrict)
}

model SyncCursor {
  id             String       @id @default(cuid())
  organizationId String
  storeId        String?
  scope          String
  cursor         String
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model SyncQueue {
  id            String             @id @default(cuid())
  storeId        String
  entity         SyncEntity
  operation      SyncOperationType
  payload        Json
  status         SyncStatus        @default(PENDING)
  attempts       Int               @default(0)
  scheduledAt    DateTime          @default(now())
  lastError      String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  store          Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model NfeImport {
  id             String       @id @default(cuid())
  organizationId String
  xmlKey         String
  supplierName   String?
  importedAt     DateTime     @default(now())
  rawPayload     Json
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, xmlKey])
}
